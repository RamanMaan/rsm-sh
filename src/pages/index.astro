---
import { getCollection } from "astro:content";
import { Github, Linkedin } from "@lucide/astro";
import ArrowCard from "../components/ArrowCard.astro";
import Link from "../components/Link.astro";
import WorkEntryHeader from "../components/WorkEntryHeader.astro";
import Layout from "../layouts/Layout.astro";
import { companyDateRange } from "../utils";

const NUM_POSTS_ON_HOMEPAGE = 3;
const NUM_WORKS_ON_HOMEPAGE = 2;

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, NUM_POSTS_ON_HOMEPAGE);

const work = (await getCollection("work"))
  .sort(
    (a, b) =>
      companyDateRange(b.data.roles).startDate.valueOf() -
      companyDateRange(a.data.roles).startDate.valueOf(),
  )
  .slice(0, NUM_WORKS_ON_HOMEPAGE);
---

<Layout title="Home" description="Raman Maan's personal website.">
  <div class="mx-auto max-w-screen-sm px-5">
    <div class="flex flex-col gap-1 mb-12">
      <h1 class="text-2xl font-semibold text-primary">Raman S. Maan</h1>
      <p class="text-sm italic text-secondary">pronounced "rum"-"in"</p>
      <div class="mt-4 w-8 h-0.5 rounded-full bg-(--color-accent)"></div>
      <p class="mt-4 text-secondary leading-relaxed">
        This is a scratch space to play around with ideas and experiments. I
        might even try and write a blog post or two.
      </p>
    </div>
    <div class="flex flex-col gap-16">

      <section class="flex flex-col gap-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold">Blog</h5>
          <Link href="/blog">See all posts</Link>
        </div>
        <ul class="flex flex-col gap-4">
          {
            blog.map((post) => (
              <li>
                <ArrowCard entry={post} />
              </li>
            ))
          }
        </ul>
      </section>

      <section class="flex flex-col gap-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold">Work Experience</h5>
          <Link href="/work">See all work </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {
            work.map((entry) => (
              <li>
                <WorkEntryHeader entry={entry} />
              </li>
            ))
          }
        </ul>
      </section>

      <section>
        <div class="flex gap-3">
          <a
            href="https://github.com/ramanmaan"
            target="_blank"
            aria-label="Raman Maan on Github"
            class="flex items-center gap-1.5 text-sm text-secondary hover:text-primary transition-colors duration-200"
          >
            <Github size={16} />
            github
          </a>
          <span class="text-secondary">/</span>
          <a
            href="https://www.linkedin.com/in/ramanmaan"
            target="_blank"
            aria-label="Raman Maan on LinkedIn"
            class="flex items-center gap-1.5 text-sm text-secondary hover:text-primary transition-colors duration-200"
          >
            <Linkedin size={16} />
            linkedin
          </a>
        </div>
      </section>
    </div>
  </div>
</Layout>
