---
import { Github, Linkedin } from "@lucide/astro";
import BackToTop from "../components/BackToTop.astro";
import Head from "../components/Head.astro";
import Link from "../components/Link.astro";
import ThemeSwitch from "../components/ThemeSwitch.astro";

type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props;
const CURRENT_YEAR = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={`${title} | rsm.sh`} description={description} />
  </head>
  <body>
    <header class="fixed top-0 left-0 right-0 z-50 py-5 backdrop-blur-sm border-b border-transparent scroll-border transition-colors duration-200">
      <div class="mx-auto max-w-screen-sm px-5">
        <div class="flex flex-wrap gap-y-2 justify-between">
          <Link href="/" underline={false}>
          <svg width="200" height="32" viewBox="0 0 200 32" xmlns="http://www.w3.org/2000/svg" style="vertical-align: -0.15em;">
            <style>
              .accent {
                fill: var(--color-accent, #22c55e);
              }
              .bg {
                fill: var(--background-color-2, #020617);
              }
              .cursor {
                animation: blink 1s steps(1) infinite;
              }
              @keyframes blink {
                50% { opacity: 0; }
              }
            </style>
            <rect class="bg" width="200" height="32" rx="6"/>
            <text x="12" y="22" font-family="Fira Code, monospace" font-size="18" dominant-baseline="alphabetic" class="accent">
              $ curl rsm.sh
            </text>
            <rect x="160" y="7" width="9" height="18" class="accent cursor"/>
          </svg>
          </Link>
          <nav class="flex gap-1 items-center">
            <Link href="/blog"> blog </Link>
            <span>
              {`/`}
            </span>
            <Link href="/work"> work </Link>
            <ThemeSwitch />
          </nav>
        </div>
      </div>
    </header>
    <main class="flex-1 pt-32 pb-24 relative">
      <slot />
      <div class="fixed bottom-4 right-4">
        <BackToTop />
      </div>
    </main>
    <footer class="py-8 text-sm border-t border-base">
      <div class="mx-auto max-w-screen-sm px-5 flex flex-col gap-4">
        <div class="flex flex-wrap items-center justify-between gap-y-3">
          <nav class="flex gap-3 text-secondary">
            <Link href="/blog">blog</Link>
            <span>/</span>
            <Link href="/work">work</Link>
            <span>/</span>
            <Link href="/theme">theme</Link>
          </nav>
          <div class="flex gap-3">
            <a
              href="https://github.com/ramanmaan"
              target="_blank"
              aria-label="Raman Maan on Github"
              class="text-secondary hover:text-primary transition-colors duration-200"
            >
              <Github size={16} />
            </a>
            <a
              href="https://www.linkedin.com/in/ramanmaan"
              target="_blank"
              aria-label="Raman Maan on LinkedIn"
              class="text-secondary hover:text-primary transition-colors duration-200"
            >
              <Linkedin size={16} />
            </a>
          </div>
        </div>
        <div class="text-secondary">
          &copy; {CURRENT_YEAR} rsm.sh
        </div>
      </div>
    </footer>
  </body>
</html>
