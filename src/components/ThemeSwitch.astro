---
import { Monitor, Moon, Sun } from "@lucide/astro";
---

<div
  class="flex items-center text-secondary *:hover:text-primary *:p-2 *:hover:bg-2 *:transition-colors *:rounded-sm gap-[inherit]"
>
  <button
    id="themeReset"
    class="hidden group"
    aria-label="Reset to system theme"
  >
    <Monitor
      class="transition-all fill-transparent group-hover:fill-current"
      size="16"
    />
  </button>
  <button class="group" id="themeToggle" aria-label="Toggle theme">
    <Sun
      class="dark-only fill-transparent transition-all group-hover:fill-current group-hover:rotate-24"
      size="16"
    />
    <Moon
      class="light-only fill-transparent transition-all group-hover:fill-current group-hover:rotate-24"
      size="16"
    />
  </button>
</div>

<script is:inline>
  const THEME_KEY = "rsm-theme";
  const darkMQ = matchMedia("(prefers-color-scheme: dark)");

  function getOverride() {
    try {
      const v = localStorage.getItem(THEME_KEY);
      return v === "light" || v === "dark" ? v : null;
    } catch { return null; }
  }

  function isDark() {
    const o = getOverride();
    return o ? o === "dark" : darkMQ.matches;
  }

  function apply(override) {
    const cl = document.documentElement.classList;
    cl.remove("light", "dark");
    if (override) cl.add(override);
  }

  function init() {
    apply(getOverride());
    document.getElementById("themeReset")?.classList.toggle("hidden", !getOverride());

    document.getElementById("themeToggle")?.addEventListener("click", () => {
      const next = isDark() ? "light" : "dark";
      try { localStorage.setItem(THEME_KEY, next); } catch {}
      apply(next);
      document.getElementById("themeReset")?.classList.remove("hidden");
    });

    document.getElementById("themeReset")?.addEventListener("click", () => {
      try { localStorage.removeItem(THEME_KEY); } catch {}
      apply(null);
      document.getElementById("themeReset")?.classList.add("hidden");
    });
  }

  document.addEventListener("DOMContentLoaded", init);
  document.addEventListener("astro:after-swap", init);
</script>
