---
import ArrowIcon from "./ArrowIcon.astro";

type Props = {
  href: string;
};

const { href } = Astro.props;
---

<a
  href={href}
  class="relative text-sm group w-fit flex py-1.5 px-2 items-center gap-1 flex-nowrap rounded border border-base hover:bg-2 hover:text-primary transition-colors duration-200 ease-in-out"
>
  <ArrowIcon class="rotate-180" />
  <slot />
</a>
