---
import { type DataEntryMap } from "astro:content";
import { companyDateRange, dateRange, shortDateRange } from "../utils";

type Props = {
  entry: DataEntryMap["work"][number];
};

const { entry } = Astro.props;
const { Content } = await entry.render();
const { roles, company } = entry.data;
const { startDate, endDate } = companyDateRange(roles);
const hasMultipleRoles = roles.length > 1;
---

<div
  class="flex flex-col border-l-2 border-base hover:border-accent pl-4 py-2 rounded-r-lg hover:bg-2 transition-colors duration-200 ease-in-out"
  transition:name={`work-entry-${entry.slug}`}
>
  <div class="text-sm text-secondary">
    {dateRange(startDate, endDate)}
  </div>
  <div class="font-semibold text-primary">
    {company}
  </div>
  {hasMultipleRoles ? (
    <ul class="mt-1 flex flex-col gap-0.5">
      {roles.map((role) => (
        <li class="flex items-baseline gap-2 text-sm">
          <span class="text-secondary">{role.title}</span>
          <span class="text-xs text-tertiary">{shortDateRange(role.dateStart, role.dateEnd)}</span>
        </li>
      ))}
    </ul>
  ) : (
    <div class="text-sm text-secondary">{roles[0].title}</div>
  )}
  <article>
    <Content />
  </article>
</div>
